{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Meta",
  "description": "JSON Schema for .chatlabs/reports/tasks/<task_id>/meta.json. Validate instances generated by /task-new against this schema.",
  "type": "object",
  "required": ["task_id", "story_id", "phase", "created_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[A-Z0-9]+-[0-9]+$",
      "examples": ["TASK-STORY001-01", "TASK-SHARED-01"],
      "description": "Globally unique task ID, format: TASK-<STORY-ID>-<NN>"
    },
    "story_id": {
      "type": "string",
      "description": "Story this task belongs to, matches directory .chatlabs/stories/<story_id>/",
      "examples": ["STORY-001", "STORY-123"]
    },
    "tapd_ticket_id": {
      "type": ["string", "null"],
      "description": "Optional TAPD ticket ID for external tracking"
    },
    "phase": {
      "type": "string",
      "enum": ["created", "doc-librarian", "planner", "generator", "evaluator", "waiting-consensus", "done"],
      "description": "Current workflow phase"
    },
    "agent": {
      "type": ["string", "null"],
      "description": "Which agent is currently responsible",
      "examples": ["doc-librarian", "planner", "generator", null]
    },
    "predecessor_task_id": {
      "type": ["string", "null"],
      "description": "Previous task ID if this task is a successor"
    },
    "trigger_reason": {
      "type": ["string", "null"],
      "enum": ["first-start", "requirement-change", "manual", "defect-fix", null]
    },
    "contract_version_at_start": {
      "type": ["string", "null"],
      "description": "Contract version when task started (semver)"
    },
    "contract_version_at_end": {
      "type": ["string", "null"],
      "description": "Contract version when task ended (semver)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp when task was created"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO8601 timestamp of last update"
    },
    "blocker_count": {
      "type": "integer",
      "default": 0,
      "minimum": 0
    },
    "file_read_count": {
      "type": "integer",
      "default": 0,
      "minimum": 0
    },
    "diff_file_count": {
      "type": "integer",
      "default": 0,
      "minimum": 0
    },
    "verdict": {
      "type": ["string", "null"],
      "enum": ["PASS", "FAIL", "WIP", null],
      "description": "Final verdict if done, null if in progress"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
