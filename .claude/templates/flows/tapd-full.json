{
  "flow_id": "tapd-full",
  "version": "1.0",
  "description": "TAPD 工单完整链路：拉取 → 共识 → 评审 → 拆 case → 实现 → 验收 → 推送代码 → 部署 → 同步回 TAPD",
  "steps": [
    {
      "id": "tapd-pull",
      "kind": "skill",
      "target": "tapd-pull",
      "phase_alias": "tapd-pull",
      "on_complete_event": null
    },
    {
      "id": "doc-librarian",
      "kind": "agent",
      "target": "doc-librarian",
      "phase_alias": "doc-librarian",
      "on_complete_event": "contract:frozen"
    },
    {
      "id": "consensus-push",
      "kind": "command",
      "target": "/tapd-consensus-push",
      "phase_alias": "consensus-push",
      "on_complete_event": "tapd:consensus-pushed"
    },
    {
      "id": "wait-approve",
      "kind": "gate",
      "target": null,
      "phase_alias": "waiting-consensus",
      "gate_event": "tapd:consensus-approved",
      "on_complete_event": "tapd:consensus-approved"
    },
    {
      "id": "planner",
      "kind": "agent",
      "target": "planner",
      "phase_alias": "planner",
      "on_complete_event": "planner:all-cases-ready"
    },
    {
      "id": "subtask-emit",
      "kind": "command",
      "target": "/tapd-subtask-emit",
      "phase_alias": "subtask-emit",
      "on_complete_event": "tapd:subtask-emitted"
    },
    {
      "id": "generator",
      "kind": "agent",
      "target": "generator",
      "phase_alias": "generator",
      "on_complete_event": "generator:all-done"
    },
    {
      "id": "evaluator",
      "kind": "agent",
      "target": "evaluator",
      "phase_alias": "evaluator",
      "on_complete_event": "evaluator:done"
    },
    {
      "id": "git-push",
      "kind": "skill",
      "target": "git-commit-push",
      "phase_alias": "git-push",
      "on_complete_event": "git:pushed"
    },
    {
      "id": "deploy",
      "kind": "skill",
      "target": "jenkins-deploy",
      "phase_alias": "deploy",
      "on_complete_event": "jenkins:deployed"
    },
    {
      "id": "subtask-close",
      "kind": "command",
      "target": "/tapd-subtask-close",
      "phase_alias": "subtask-close",
      "on_complete_event": "tapd:subtask-closed"
    },
    {
      "id": "sprint-review",
      "kind": "command",
      "target": "/sprint-review",
      "phase_alias": "sprint-review",
      "on_complete_event": null
    },
    {
      "id": "done",
      "kind": "terminal",
      "target": null,
      "phase_alias": "done",
      "on_complete_event": null
    }
  ]
}
